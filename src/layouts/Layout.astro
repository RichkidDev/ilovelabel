---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, 'https://ilovelabel.com');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="shipping label crop, flipkart label crop, meesho label crop, label printer, thermal label, 4x6 label, shipping label tool, ecommerce seller tool, crop shipping label online, free label cropper" />
    <meta name="author" content="ILoveLabel" />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="ILoveLabel" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "ILoveLabel",
      "url": "https://ilovelabel.com",
      "description": description,
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "INR" },
      "featureList": [
        "Crop Flipkart shipping labels",
        "Crop Meesho shipping labels",
        "Remove invoice from label PDF",
        "Bulk PDF upload",
        "SKU grouping and sorting",
        "Thermal label printer ready output"
      ]
    })} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    background: #f5f3f9;
    font-family: 'Inter', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    min-height: 100vh;
    color: #333;
    -webkit-font-smoothing: antialiased;
  }

  .container {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 15px;
  }

  .card {
    background: #fff;
    border-radius: 12px;
  }

  .card-body {
    padding: 1.5rem;
  }

  .table {
    width: 100%;
    border-collapse: collapse;
  }

  .table th,
  .table td {
    padding: 8px 12px;
    border-bottom: 1px solid #dee2e6;
    text-align: left;
  }

  .table-sm th,
  .table-sm td {
    padding: 4px 8px;
  }
</style>

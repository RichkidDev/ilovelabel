---
import Layout from '../layouts/Layout.astro';
import CropApp from '../components/CropApp';
import '../styles/app.css';
---

<Layout
  title="ILoveLables - Free Shipping Label Cropper for Flipkart & Meesho Sellers"
  description="Free online tool to crop shipping labels from Flipkart and Meesho PDFs. Removes invoice, trims whitespace, and outputs clean labels ready for thermal label printers. Bulk upload supported."
>
  <!-- Navbar -->
  <nav class="navbar">
    <div class="container">
      <a href="/" class="navbar-brand">
        <span class="brand-i">I</span><svg class="brand-heart" viewBox="0 0 24 24" width="22" height="22" fill="#ff3b5c"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg><span class="brand-label">Lables</span>
      </a>
      <div class="navbar-right">
        <a href="/guide" class="nav-guide-link">How to Use</a>
        <span class="navbar-tagline">The #1 Label Tool for Indian Sellers</span>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="hero-section">
    <p class="hero-eyebrow">Trusted by 1000+ Indian e-commerce sellers</p>
    <h1>Stop Wasting Time on Labels.<br/>Start Shipping Faster.</h1>
    <p class="hero-sub">
      One click to crop, clean, and prepare your Flipkart &amp; Meesho shipping labels.
      No scissors. No guesswork. Just print-ready labels in seconds.
    </p>
  </section>

  <!-- Interactive Crop Tool (React island) -->
  <div class="container">
    <CropApp client:only="react" />

    <!-- How It Works Section -->
    <section class="how-it-works-section">
      <h2 class="features-heading">How It Works</h2>
      <div class="hiw-steps">
        <div class="hiw-step">
          <div class="hiw-step-number">1</div>
          <div class="hiw-step-icon" aria-hidden="true">&#128228;</div>
          <h3>Upload Your Label PDF</h3>
          <p>Select Flipkart or Meesho tab, then drag & drop your shipping label PDF.</p>
        </div>
        <div class="hiw-step">
          <div class="hiw-step-number">2</div>
          <div class="hiw-step-icon" aria-hidden="true">&#9986;&#65039;</div>
          <h3>Auto-Crop & Clean</h3>
          <p>Invoice removed, whitespace trimmed, labels extracted and sorted by SKU.</p>
        </div>
        <div class="hiw-step">
          <div class="hiw-step-number">3</div>
          <div class="hiw-step-icon" aria-hidden="true">&#128424;</div>
          <h3>Download & Print</h3>
          <p>Get print-ready labels sized for your thermal printer. Done in seconds.</p>
        </div>
      </div>
      <div class="text-center" style="margin-top: 18px;">
        <a href="/guide" class="hiw-cta">View Full Step-by-Step Guide &rarr;</a>
      </div>
    </section>

    <!-- Features Section -->
    <section class="features-section">
      <h2 class="features-heading">Why sellers love us</h2>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon" aria-hidden="true">&#9986;&#65039;</div>
          <h3>Smart Auto-Crop</h3>
          <p>Invoice removed, whitespace trimmed, label extracted — all automatically. Zero manual work.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon" aria-hidden="true">&#128640;</div>
          <h3>Bulk Processing</h3>
          <p>Got 50 orders? Upload all PDFs at once. Download one merged file or individual labels.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon" aria-hidden="true">&#127991;&#65039;</div>
          <h3>SKU-wise Sorting</h3>
          <p>Labels grouped by SKU automatically. Pack faster, dispatch sooner, grow bigger.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon" aria-hidden="true">&#128274;</div>
          <h3>100% Private</h3>
          <p>Your PDFs never leave your device. Everything runs in your browser — no uploads, no servers.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon" aria-hidden="true">&#127912;</div>
          <h3>Thermal Printer Ready</h3>
          <p>Output perfectly sized for 4x6 inch thermal label printers. Just print and stick.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon" aria-hidden="true">&#128176;</div>
          <h3>100% Free Forever</h3>
          <p>No signup. No limits. No hidden charges. Built for sellers, by sellers.</p>
        </div>
      </div>
    </section>
  </div>

  <!-- Footer -->
  <footer class="site-footer">
    <p class="footer-brand">
      <span class="brand-i">I</span><svg class="brand-heart" viewBox="0 0 24 24" width="14" height="14" fill="#ff3b5c"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg><span class="brand-label">Lables</span>
    </p>
    <p>Made with &#10084;&#65039; for Indian e-commerce sellers</p>
    <p class="footer-privacy">&#128274; Your data stays on your device. Always.</p>
  </footer>
</Layout>
